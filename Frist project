books = ["Python Basics", "AI Introduction", "Data Science"]

def show_books():
    print("\nBooks in Library:")
    if len(books) == 0:
        print("No books available")
    else:
        for book in books:
            print("- " + book)

def add_book():
    book = input("Enter book name: ")
    books.append(book)
    print("Book added successfully")

def remove_book():
    book = input("Enter book name to remove: ")
    if book in books:
        books.remove(book)
        print("Book removed successfully")
    else:
        print("Book not found")

def search_book():
    book = input("Enter book name to search: ")
    if book in books:
        print("Book found in library")
    else:
        print("Book not found")

while True:
    print("\nLibrary Management System")
    print("1. Show Books")
    print("2. Add Book")
    print("3. Remove Book")
    print("4. Search Book")
    print("5. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        show_books()
    elif choice == "2":
        add_book()
    elif choice == "3":
        remove_book()
    elif choice == "4":
        search_book()
    elif choice == "5":
        print("Program ended")
        break
    else:
        print("Invalid choice")
